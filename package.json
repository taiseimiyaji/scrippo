{
  "name": "scrippo",
  "version": "1.0.2",
  "description": "Your screen, distilled into a daily report. — screen + 日報 = scrippo",
  "type": "module",
  "bin": {
    "scrippo": "dist/cli.js"
  },
  "files": [
    "dist",
    "ocr-src",
    "templates"
  ],
  "scripts": {
    "test": "node --test 'test/*.test.ts'",
    "build:ocr": "./ocr-src/build.sh",
    "build:js": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run build:js",
    "postinstall": "./ocr-src/build.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taiseimiyaji/scrippo.git"
  },
  "homepage": "https://github.com/taiseimiyaji/scrippo#readme",
  "bugs": {
    "url": "https://github.com/taiseimiyaji/scrippo/issues"
  },
  "keywords": [
    "macos",
    "ocr",
    "daily-report",
    "nippo",
    "screenshot",
    "cli",
    "vision"
  ],
  "author": "Taisei Miyaji",
  "license": "MIT",
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.143.0"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
